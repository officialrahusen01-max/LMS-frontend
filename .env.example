# Use same-origin API so Next.js can proxy to Express (see next.config.mjs → rewrites).
# Must match Lib/.env PORT (5000 is typical; 443 on Windows often needs Admin).
NEXT_PUBLIC_API_BASE_URL=/api/v1
BACKEND_ORIGIN=https://lms-qh1c.onrender.com

# Optional: call Express directly from the browser (no proxy). Only if CORS + port work.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000/api/v1

# Student chat — ChatGPT-style replies for any LMS question (recommended).
# Get a key at https://console.groq.com — never commit real keys.
# GROQ_API_KEY=
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# Optional tuning:
# GROQ_MAX_TOKENS=2048
# GROQ_TEMPERATURE=0.65
